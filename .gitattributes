# Linguist overrides - ignore generated files
src-tauri/gen/** linguist-generated
src-tauri/icons/** linguist-generated
target/** linguist-generated
Cargo.lock linguist-generated

# Explicitly ignore Makefile in target directory
target/**/Makefile linguist-generated
target/**/makefile linguist-generated
target/**/*.mk linguist-generated

# Mark source files
*.rs linguist-language=Rust
*.toml linguist-language=TOML
*.yaml linguist-language=YAML
*.yml linguist-language=YAML
*.html linguist-language=HTML
*.css linguist-language=CSS
*.js linguist-language=JavaScript

# Ignore documentation
*.md linguist-documentation
LICENSE linguist-documentation